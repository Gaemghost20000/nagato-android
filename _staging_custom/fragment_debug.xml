<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/nagato_background">

    <!-- Agent status bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/nagato_surface"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/agent_status_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Agent: ○ Stopped | Projects: 0 active"
            android:textColor="@color/nagato_text_primary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/agent_start_btn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Start"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/agent_stop_btn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Stop"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Log tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/nagato_surface_variant">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agent Logs"
            android:padding="12dp"
            android:textColor="@color/nagato_primary"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="System Logs"
            android:padding="12dp"
            android:textColor="@color/nagato_text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Boot Logs"
            android:padding="12dp"
            android:textColor="@color/nagato_text_secondary" />

    </LinearLayout>

    <!-- Log RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/debug_log_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
